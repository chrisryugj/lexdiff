/**
 * Upload Progress Panel Component
 * Phase 3: Upload approved laws to File Search Store
 */

'use client'

import { useState, useEffect } from 'react'
import { Button } from '@/components/ui/button'
import { Progress } from '@/components/ui/progress'

interface SavedLaw {
  lawId: string
  lawName: string
  effectiveDate: string
  articleCount: number
  fileSize: number
  savedAt: string
}

interface UploadResult {
  lawId: string
  lawName?: string
  status: 'success' | 'error'
  error?: string
  documentId?: string
}

interface UploadProgressPanelProps {
  savedLaws: SavedLaw[]
  onUploadComplete: () => void
}

export function UploadProgressPanel({ savedLaws, onUploadComplete }: UploadProgressPanelProps) {
  const [selectedLaws, setSelectedLaws] = useState<Set<string>>(new Set())
  const [uploading, setUploading] = useState(false)
  const [results, setResults] = useState<UploadResult[]>([])
  const [currentIndex, setCurrentIndex] = useState(0)

  function toggleSelection(lawId: string) {
    const newSet = new Set(selectedLaws)
    if (newSet.has(lawId)) {
      newSet.delete(lawId)
    } else {
      newSet.add(lawId)
    }
    setSelectedLaws(newSet)
  }

  function selectAll() {
    setSelectedLaws(new Set(savedLaws.map((l) => l.lawId)))
  }

  function clearSelection() {
    setSelectedLaws(new Set())
  }

  async function startUpload() {
    if (selectedLaws.size === 0) return

    setUploading(true)
    setResults([])
    setCurrentIndex(0)

    try {
      const lawIds = Array.from(selectedLaws)

      const response = await fetch('/api/admin/upload-to-store', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ lawIds })
      })

      const data = await response.json()

      if (data.success) {
        setResults(data.results)
        setCurrentIndex(lawIds.length)

        // Clear selection for successful uploads
        const failedLaws = data.results.filter((r: UploadResult) => r.status === 'error').map((r: UploadResult) => r.lawId)
        setSelectedLaws(new Set(failedLaws))
      } else {
        alert('업로드 실패: ' + data.error)
      }
    } catch (error: any) {
      alert('업로드 중 오류: ' + error.message)
    } finally {
      setUploading(false)
      onUploadComplete()
    }
  }

  const selectedCount = selectedLaws.size
  const successCount = results.filter((r) => r.status === 'success').length
  const errorCount = results.filter((r) => r.status === 'error').length

  return (
    <div className="space-y-4">
      <div>
        <h2 className="text-xl font-bold text-white mb-2">📤 File Search Store 업로드</h2>
        <p className="text-sm text-gray-400">
          로컬에 저장된 법령을 선택하여 File Search Store에 업로드합니다.
        </p>
      </div>

      {/* Selection Controls */}
      <div className="flex items-center justify-between p-4 bg-gray-800 border border-gray-700 rounded-lg">
        <div className="text-sm text-gray-300">
          {selectedCount > 0 ? `${selectedCount}개 선택됨` : '선택된 법령 없음'}
        </div>
        <div className="flex gap-2">
          <Button onClick={selectAll} variant="outline" size="sm" className="border-gray-600 text-gray-300">
            전체 선택
          </Button>
          <Button onClick={clearSelection} variant="outline" size="sm" className="border-gray-600 text-gray-300">
            선택 해제
          </Button>
          <Button
            onClick={startUpload}
            disabled={selectedCount === 0 || uploading}
            className="bg-blue-600 hover:bg-blue-700"
          >
            {uploading ? '업로드 중...' : '업로드 시작'}
          </Button>
        </div>
      </div>

      {/* Upload Progress */}
      {uploading && (
        <div className="p-4 bg-gray-800 border border-gray-700 rounded-lg">
          <div className="mb-2">
            <p className="text-sm text-gray-300">
              업로드 중... ({currentIndex}/{selectedCount})
            </p>
          </div>
          <Progress value={(currentIndex / selectedCount) * 100} className="h-2" />
        </div>
      )}

      {/* Upload Results */}
      {results.length > 0 && (
        <div className="p-4 bg-gray-800 border border-gray-700 rounded-lg">
          <h3 className="font-medium text-white mb-2">업로드 결과</h3>
          <div className="space-y-1 text-sm">
            <p className="text-green-400">✓ 성공: {successCount}개</p>
            <p className="text-red-400">✗ 실패: {errorCount}개</p>
          </div>

          {errorCount > 0 && (
            <div className="mt-3 space-y-2">
              <p className="text-sm text-gray-300">실패한 법령:</p>
              <div className="max-h-40 overflow-y-auto space-y-1">
                {results
                  .filter((r) => r.status === 'error')
                  .map((r) => (
                    <div key={r.lawId} className="text-xs text-red-400 bg-red-900/20 p-2 rounded">
                      {r.lawName || r.lawId}: {r.error}
                    </div>
                  ))}
              </div>
            </div>
          )}
        </div>
      )}

      {/* Saved Laws List */}
      <div className="space-y-2">
        <h3 className="font-medium text-white">저장된 법령 목록 ({savedLaws.length})</h3>
        {savedLaws.length === 0 ? (
          <div className="p-8 bg-gray-800 border border-gray-700 rounded-lg text-center">
            <p className="text-gray-500">저장된 법령이 없습니다</p>
            <p className="text-sm text-gray-600 mt-1">먼저 법령을 검색하고 저장해주세요</p>
          </div>
        ) : (
          <div className="space-y-2 max-h-96 overflow-y-auto">
            {savedLaws.map((law) => {
              const isSelected = selectedLaws.has(law.lawId)
              const uploadResult = results.find((r) => r.lawId === law.lawId)

              return (
                <div
                  key={law.lawId}
                  onClick={() => !uploading && toggleSelection(law.lawId)}
                  className={`p-4 border rounded-lg cursor-pointer transition-colors ${
                    isSelected
                      ? 'bg-blue-900/30 border-blue-700'
                      : 'bg-gray-800 border-gray-700 hover:border-gray-600'
                  } ${uploading ? 'opacity-50 cursor-not-allowed' : ''}`}
                >
                  <div className="flex items-start justify-between">
                    <div>
                      <div className="font-medium text-white">{law.lawName}</div>
                      <div className="text-sm text-gray-400 mt-1">
                        법령 ID: {law.lawId} · {law.articleCount}개 조문 · {(law.fileSize / 1024).toFixed(2)} KB
                      </div>
                      <div className="text-xs text-gray-500 mt-1">
                        저장: {new Date(law.savedAt).toLocaleString()}
                      </div>
                    </div>
                    <div className="flex flex-col gap-1">
                      {isSelected && !uploadResult && (
                        <span className="px-2 py-1 bg-blue-900/30 border border-blue-700 rounded text-xs text-blue-400">
                          선택됨
                        </span>
                      )}
                      {uploadResult?.status === 'success' && (
                        <span className="px-2 py-1 bg-green-900/30 border border-green-700 rounded text-xs text-green-400">
                          ✓ 업로드 완료
                        </span>
                      )}
                      {uploadResult?.status === 'error' && (
                        <span className="px-2 py-1 bg-red-900/30 border border-red-700 rounded text-xs text-red-400">
                          ✗ 실패
                        </span>
                      )}
                    </div>
                  </div>
                </div>
              )
            })}
          </div>
        )}
      </div>
    </div>
  )
}
