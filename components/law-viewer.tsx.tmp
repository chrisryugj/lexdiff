      }
      // ?†пЄП jo ?МлЭЉлѓЄнД∞ ?Ьк±∞ - APIк∞А ?Шл™ї??м°∞лђЄ??л∞ШнЩШ?ШлКФ л≤ДкЈЄ л∞©м?
      // ?Дм≤і л≤Хл†є??к∞А?ЄмШ® ???ілЭЉ?імЦЄ?ЄмЧР???ДнД∞лІ?      console.log("[citation] Fetching full law, will filter on client:", { cleanedLawName, articleLabel, joCode })
      // ?†пЄП efYdл•??ђмЪ©?Шм? ?КмЭМ - мµЬмЛ† ?ЬнЦЙ л≤Дм†Д м°∞нЪМ
      // ?Ал≤Хк∞Ь?ХмЬЉл°??ЄнХЬ м°∞лђЄ ?ДлЭљ л∞©м?

      try {

        const eflawRes = await fetch(`/api/eflaw?${identifierParams.toString()}`)

        if (!eflawRes.ok) {

          throw new Error(`HTTP ${eflawRes.status}`)
        }

        const eflawJson = await eflawRes.json()


        const lawData = eflawJson?.л≤Хл†є


        const rawArticleUnits = lawData?.м°∞лђЄ?.м°∞лђЄ?®мЬД


