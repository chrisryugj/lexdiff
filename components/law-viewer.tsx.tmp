                    <GitCompare className="h-3.5 w-3.5 mr-1" />
                    ?†¬Јкµђл≤?лєДкµР
                  </Button>
                  <Button variant="outline" size="sm" onClick={() => onSummarize?.(activeArticle.jo)} className="h-7 px-2">
                    <Sparkles className="h-3.5 w-3.5 mr-1" />
