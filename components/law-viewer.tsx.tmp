          })
          return
        }

        // ?†пЄП м°∞лђЄ?імЪ©???Ьл™©лІ??ИлКФ к≤љмЪ∞к∞А лІОмЬЉлѓАл°???л∞∞мЧі???НмК§?Єл°Ь л≥А??        let rawContent = targetUnit.м°∞лђЄ?імЪ© || ""
        const title = targetUnit.м°∞лђЄ?Ьл™© || ""

        console.log('[Citation] Raw unit data:', {
