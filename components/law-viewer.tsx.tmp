          totalArticles: articleUnits.length,
          firstArticle: articleUnits[0] ? {
            м°∞лђЄ?? articleUnits[0]?.м°∞лђЄ??
            м°∞лђЄл≤ИнШЄ: articleUnits[0]?.м°∞лђЄл≤ИнШЄ
          } : null
        })



          м°∞лђЄ?? u?.м°∞лђЄ??
          м°∞лђЄл≤ИнШЄ: u?.м°∞лђЄл≤ИнШЄ,
          м°∞лђЄ?Ьл™©: u?.м°∞лђЄ?Ьл™©?.substring(0, 30)
        })))

        // ?†пЄП м°∞лђЄ?ђл?к∞А "м°∞лђЄ"??к≤ГлІМ м∞ЊкЄ∞ (?ДлђЄ ?ЬмЩЄ)


        const targetUnit =
          articleUnits.find((unit: any) => {
            const isArticle = unit?.м°∞лђЄ?ђл? === "м°∞лђЄ"
            const hasKey = typeof unit?.м°∞лђЄ??=== "string"
            const matches = hasKey && unit.м°∞лђЄ??startsWith(normalizedJo)
            console.log('[Citation] Check unit:', {
              м°∞лђЄ?? unit?.м°∞лђЄ??
              м°∞лђЄл≤ИнШЄ: unit?.м°∞лђЄл≤ИнШЄ,
              м°∞лђЄ?ђл?: unit?.м°∞лђЄ?ђл?,
              isArticle,
              hasKey,
              matches
            })
            return isArticle && hasKey && matches
          }) ||
          articleUnits.find((unit: any) => {
            const num = typeof unit?.м°∞лђЄл≤ИнШЄ === "string" ? unit.м°∞лђЄл≤ИнШЄ.replace(/\D/g, "") : ""
            const targetNum = articleLabel.replace(/\D/g, "")
            console.log('[Citation] Fallback check:', {
              м°∞лђЄл≤ИнШЄ: unit?.м°∞лђЄл≤ИнШЄ,
