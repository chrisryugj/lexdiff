                              <ExternalLink className="h-3.5 w-3.5 text-blue-400 group-hover:text-blue-300 shrink-0 mt-0.5" />
                              <span className="font-medium text-blue-300 group-hover:text-blue-200 text-base">
                                {law.lawName}
                              </span>
                            </div>
